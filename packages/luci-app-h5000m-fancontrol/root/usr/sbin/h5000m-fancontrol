#!/bin/sh

find_pwm() {
	for pwm in /sys/class/hwmon/hwmon*/pwm1; do
		[ -e "${pwm}" ] || continue
		echo "${pwm}"
		return 0
	done
	return 1
}

find_temp() {
	for temp in /sys/class/thermal/thermal_zone*/temp /sys/class/hwmon/hwmon*/temp*_input; do
		[ -e "${temp}" ] || continue
		echo "${temp}"
		return 0
	done
	return 1
}

find_fan_rpm() {
	for fan in /sys/class/hwmon/hwmon*/fan1_input /sys/class/hwmon/hwmon*/fan*_input; do
		[ -e "${fan}" ] || continue
		echo "${fan}"
		return 0
	done
	return 1
}

read_temp_c() {
	local file="$1"
	local value

	value="$(cat "${file}" 2>/dev/null || echo "")"
	case "${value}" in
		''|*[!0-9-]*)
			echo ""
			;;
		*)
			if [ "${value}" -gt 1000 ] 2>/dev/null || [ "${value}" -lt -1000 ] 2>/dev/null; then
				echo $((value / 1000))
			else
				echo "${value}"
			fi
			;;
	esac
}

temp_label() {
	local file="$1"
	local base label idx

	case "${file}" in
		/sys/class/thermal/thermal_zone*/temp)
			base="${file%/temp}"
			cat "${base}/type" 2>/dev/null || echo "${base##*/}"
			;;
		/sys/class/hwmon/hwmon*/temp*_input)
			base="${file%/*}"
			idx="${file##*/temp}"
			idx="${idx%_input}"
			label="$(cat "${base}/temp${idx}_label" 2>/dev/null || true)"
			[ -n "${label}" ] || label="$(cat "${base}/name" 2>/dev/null || true)"
			[ -n "${label}" ] || label="${base##*/}"
			echo "${label}"
			;;
		*)
			echo "${file##*/}"
			;;
	esac
}

print_temp_status() {
	local file label lower value count cpu wifi_count phy_count other_count
	local cpu_temp wifi1_temp wifi2_temp phy_temp other_temp
	local first_temp second_temp third_temp

	count=0
	wifi_count=0
	phy_count=0
	other_count=0

	for file in /sys/class/thermal/thermal_zone*/temp /sys/class/hwmon/hwmon*/temp*_input; do
		[ -e "${file}" ] || continue
		value="$(read_temp_c "${file}")"
		[ -n "${value}" ] || continue
		label="$(temp_label "${file}")"
		lower="$(printf '%s' "${label}" | tr 'A-Z' 'a-z')"
		count=$((count + 1))
		[ "${count}" -eq 1 ] && first_temp="${value}"
		[ "${count}" -eq 2 ] && second_temp="${value}"
		[ "${count}" -eq 3 ] && third_temp="${value}"
		echo "temp${count}_label=${label}"
		echo "temp${count}_value=${value}"

		case "${lower}" in
			*cpu*|*soc*|*mt798*|*thermal*)
				[ -n "${cpu_temp:-}" ] || cpu_temp="${value}"
				;;
			*mt799*|*wifi*|*radio*)
				wifi_count=$((wifi_count + 1))
				[ "${wifi_count}" -eq 1 ] && wifi1_temp="${value}"
				[ "${wifi_count}" -eq 2 ] && wifi2_temp="${value}"
				;;
			*mdio*|*phy*)
				phy_count=$((phy_count + 1))
				[ "${phy_count}" -eq 1 ] && phy_temp="${value}"
				;;
			*)
				other_count=$((other_count + 1))
				[ "${other_count}" -eq 1 ] && other_temp="${value}"
				;;
		esac
	done

	[ -n "${cpu_temp:-}" ] || cpu_temp="${first_temp:-${other_temp:-}}"
	[ -n "${wifi1_temp:-}" ] || wifi1_temp="${second_temp:-}"
	[ -n "${wifi2_temp:-}" ] || wifi2_temp="${third_temp:-}"
	echo "cpu_temp=${cpu_temp:-}"
	echo "wifi1_temp=${wifi1_temp:-}"
	echo "wifi2_temp=${wifi2_temp:-}"
	echo "phy_temp=${phy_temp:-}"
}

find_module_temp() {
	local file value

	for file in /tmp/cache_base_info_* /tmp/cache_*info*; do
		[ -f "${file}" ] || continue
		value="$(sed -n 's/.*"key"[[:space:]]*:[[:space:]]*"temperature"[^}]*"value"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "${file}" 2>/dev/null | head -n 1 | grep -Eo -- '-?[0-9]+' | head -n 1)"
		[ -n "${value}" ] || continue
		echo "${value}"
		return 0
	done

	for file in /tmp/qmodem* /tmp/*qmodem* /var/run/qmodem* /var/run/*qmodem*; do
		[ -f "${file}" ] || continue
		value="$(grep -Eoi '(temp|temperature|温度)[^0-9-]*-?[0-9]+' "${file}" 2>/dev/null | head -n 1 | grep -Eo -- '-?[0-9]+' | tail -n 1)"
		[ -n "${value}" ] || continue
		echo "${value}"
		return 0
	done

	return 1
}

clamp_pwm() {
	local value="$1"
	[ "${value}" -lt 0 ] && value=0
	[ "${value}" -gt 255 ] && value=255
	echo "${value}"
}

calc_auto_pwm() {
	local temp="$1"
	local low="$2"
	local high="$3"
	local min="$4"
	local max="$5"

	[ "${temp}" -le "${low}" ] && {
		echo "${min}"
		return 0
	}

	[ "${temp}" -ge "${high}" ] && {
		echo "${max}"
		return 0
	}

	echo $((min + (temp - low) * (max - min) / (high - low)))
}

apply_once() {
	local enabled mode manual min max low high pwm temp_file temp temp_c value

	enabled="$(uci -q get h5000m_fancontrol.settings.enabled || echo 1)"
	mode="$(uci -q get h5000m_fancontrol.settings.mode || echo auto)"
	manual="$(uci -q get h5000m_fancontrol.settings.manual_pwm || echo 160)"
	min="$(uci -q get h5000m_fancontrol.settings.min_pwm || echo 80)"
	max="$(uci -q get h5000m_fancontrol.settings.max_pwm || echo 255)"
	low="$(uci -q get h5000m_fancontrol.settings.low_temp || echo 45)"
	high="$(uci -q get h5000m_fancontrol.settings.high_temp || echo 70)"
	[ "${high}" -le "${low}" ] && high=$((low + 1))

	pwm="$(find_pwm)" || {
		logger -t h5000m-fancontrol "未找到 PWM 风扇控制节点"
		return 1
	}

	if [ "${enabled}" != "1" ] || [ "${mode}" = "off" ]; then
		value=0
	elif [ "${mode}" = "manual" ]; then
		value="${manual}"
	else
		temp_file="$(find_temp)" || {
			logger -t h5000m-fancontrol "未找到温度读取节点"
			return 1
		}
		temp="$(cat "${temp_file}" 2>/dev/null || echo 0)"
		temp_c=$((temp / 1000))
		value="$(calc_auto_pwm "${temp_c}" "${low}" "${high}" "${min}" "${max}")"
	fi

	value="$(clamp_pwm "${value}")"
	echo "${value}" > "${pwm}"
	logger -t h5000m-fancontrol "设置风扇 PWM=${value}"
}

case "${1:-apply}" in
	apply)
		apply_once
		;;
	status)
		pwm="$(find_pwm 2>/dev/null || true)"
		fan="$(find_fan_rpm 2>/dev/null || true)"
		temp="$(find_temp 2>/dev/null || true)"
		echo "pwm=${pwm:-}"
		[ -n "${pwm:-}" ] && echo "pwm_value=$(cat "${pwm}" 2>/dev/null || true)"
		echo "fan=${fan:-}"
		if [ -n "${fan:-}" ]; then
			echo "fan_feedback=1"
			echo "fan_rpm=$(cat "${fan}" 2>/dev/null || true)"
		else
			echo "fan_feedback=0"
			echo "fan_rpm="
		fi
		echo "temp=${temp:-}"
		[ -n "${temp:-}" ] && echo "temp_value=$(cat "${temp}" 2>/dev/null || true)"
		module_temp="$(find_module_temp 2>/dev/null || true)"
		echo "module_temp=${module_temp:-}"
		print_temp_status
		;;
	*)
		echo "用法：$0 {apply|status}"
		exit 1
		;;
esac

exit 0
